rules_version = '2';

/**
 * Firebase Storage Security Rules
 *
 * Restricts file uploads/downloads to authenticated users and enforces
 * size limits + content-type validation to prevent abuse.
 *
 * Adjust paths and limits as your app's storage needs grow.
 */
service firebase.storage {
  match /b/{bucket}/o {

    // ── Deny all by default ─────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ── User Profile Avatars ────────────────────────────────────────────
    // Path: /users/{userId}/avatar/{filename}
    match /users/{userId}/avatar/{fileName} {
      // Anyone authenticated can view profile pictures
      allow read: if request.auth != null;

      // Only the owner can upload/overwrite their avatar
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            // Max 5 MB
                            && request.resource.size < 5 * 1024 * 1024
                            // Images only
                            && request.resource.contentType.matches('image/.*');

      // Explicit delete — owner only (no size/type check needed)
      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }

    // ── User Uploads (generic) ──────────────────────────────────────────
    // Path: /users/{userId}/uploads/{fileName}
    match /users/{userId}/uploads/{fileName} {
      // Owner read only
      allow read: if request.auth != null && request.auth.uid == userId;

      // Owner create/update with size limit
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            // Max 10 MB
                            && request.resource.size < 10 * 1024 * 1024;

      // Explicit delete — owner only
      allow delete: if request.auth != null
                    && request.auth.uid == userId;
    }
  }
}
