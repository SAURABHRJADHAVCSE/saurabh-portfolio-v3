# AI Provider API Keys
# Get these from:
# - Gemini: https://ai.google.dev/gemini-api/docs
# - Kie.AI: https://kie.ai/

# Gemini API Key (server-only � do NOT use NEXT_PUBLIC_ prefix)
GEMINI_API_KEY=your_gemini_api_key_here

# Kie.AI API Key (server-only � do NOT use NEXT_PUBLIC_ prefix)
KIEAI_API_KEY=your_kieai_api_key_here

# Firebase Admin SDK � service account JSON (server-only)
# Option A: Set this env var with the full JSON string
# Option B: Set GOOGLE_APPLICATION_CREDENTIALS to a file path
FIREBASE_SERVICE_ACCOUNT_KEY={}

# Firebase API Keys (UAT)
NEXT_PUBLIC_FIREBASE_UAT_API_KEY=your_uat_firebase_key_here
NEXT_PUBLIC_FIREBASE_UAT_PROJECT_ID=your_uat_project_id_here
NEXT_PUBLIC_FIREBASE_UAT_AUTH_DOMAIN=your_uat_auth_domain_here
NEXT_PUBLIC_FIREBASE_UAT_STORAGE_BUCKET=your_uat_storage_bucket_here
NEXT_PUBLIC_FIREBASE_UAT_MESSAGING_SENDER_ID=your_uat_sender_id_here
NEXT_PUBLIC_FIREBASE_UAT_APP_ID=your_uat_app_id_here
NEXT_PUBLIC_FIREBASE_UAT_MEASUREMENT_ID=your_uat_measurement_id_here
NEXT_PUBLIC_FIREBASE_UAT_VAPID_KEY=your_uat_vapid_key_here

# Firebase API Keys (PROD)
NEXT_PUBLIC_FIREBASE_PROD_API_KEY=your_prod_firebase_key_here
NEXT_PUBLIC_FIREBASE_PROD_PROJECT_ID=your_prod_project_id_here
NEXT_PUBLIC_FIREBASE_PROD_AUTH_DOMAIN=your_prod_auth_domain_here
NEXT_PUBLIC_FIREBASE_PROD_STORAGE_BUCKET=your_prod_storage_bucket_here
NEXT_PUBLIC_FIREBASE_PROD_MESSAGING_SENDER_ID=your_prod_sender_id_here
NEXT_PUBLIC_FIREBASE_PROD_APP_ID=your_prod_app_id_here
NEXT_PUBLIC_FIREBASE_PROD_MEASUREMENT_ID=your_prod_measurement_id_here
NEXT_PUBLIC_FIREBASE_PROD_VAPID_KEY=your_prod_vapid_key_here

# Upstash Redis (server-only) — used for rate limiting
# If these are missing, rate limiting is disabled (all requests allowed).
# Create a free Redis database at https://console.upstash.com
# Then copy the REST URL and token from: Console → your DB → REST API
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# Public app URL — used for metadata, CSRF origin checks, sitemap
NEXT_PUBLIC_APP_URL=http://localhost:3000
